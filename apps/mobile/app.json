{
  "expo": {
    "name": "PrepSDE",
    "slug": "prepsde",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "prepsde",
    "splash": {
      "backgroundColor": "#0d0d0d"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "package": "com.prepsde.app"
    },
    "ios": {
      "bundleIdentifier": "com.prepsde.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
